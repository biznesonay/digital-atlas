generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int             @id @default(autoincrement())
  email                String          @unique
  password             String?
  name                 String
  role                 Role            @default(EDITOR)
  isActive             Boolean         @default(true)
  lastLoginAt          DateTime?
  passwordResetToken   String?         @unique
  passwordResetExpires DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  sessions      Session[]
  importHistory ImportHistory[]
}

enum Role {
  SUPER_ADMIN
  EDITOR
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InfrastructureType {
  id       Int     @id @default(autoincrement())
  icon     String
  color    String
  order    Int     @default(0)
  isActive Boolean @default(true)

  translations InfrastructureTypeTranslation[]
  objects      Object[]
}

model InfrastructureTypeTranslation {
  id                   Int    @id @default(autoincrement())
  infrastructureTypeId Int
  languageCode         String
  name                 String

  infrastructureType InfrastructureType @relation(fields: [infrastructureTypeId], references: [id], onDelete: Cascade)

  @@unique([infrastructureTypeId, languageCode])
}

model Region {
  id       Int     @id @default(autoincrement())
  code     String?
  parentId Int?

  parent       Region?             @relation("RegionHierarchy", fields: [parentId], references: [id])
  children     Region[]            @relation("RegionHierarchy")
  translations RegionTranslation[]
  objects      Object[]
}

model RegionTranslation {
  id           Int    @id @default(autoincrement())
  regionId     Int
  languageCode String
  name         String

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, languageCode])
}

model Object {
  id                   Int      @id @default(autoincrement())
  infrastructureTypeId Int
  regionId             Int
  latitude             Float?
  longitude            Float?
  googleMapsUrl        String?
  website              String?
  logoUrl              String?
  imageUrl             String?
  geocodingStatus      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  infrastructureType InfrastructureType           @relation(fields: [infrastructureTypeId], references: [id])
  region             Region                       @relation(fields: [regionId], references: [id])
  translations       ObjectTranslation[]
  phones             Phone[]
  organizations      Organization[]
  priorityDirections ObjectPriorityDirection[]
}

model ObjectTranslation {
  id           Int     @id @default(autoincrement())
  objectId     Int
  languageCode String
  name         String  @db.VarChar(1000)
  address      String  @db.VarChar(1000)
  isPublished  Boolean @default(false)

  object Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([objectId, languageCode])
}

model Phone {
  id       Int       @id @default(autoincrement())
  objectId Int
  number   String
  type     PhoneType @default(MAIN)
  order    Int       @default(0)

  object Object @relation(fields: [objectId], references: [id], onDelete: Cascade)
}

enum PhoneType {
  MAIN
  ADDITIONAL
  FAX
  MOBILE
}

model PriorityDirection {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  order    Int     @default(0)
  isActive Boolean @default(true)

  objects ObjectPriorityDirection[]
}

model ObjectPriorityDirection {
  objectId            Int
  priorityDirectionId Int

  object            Object            @relation(fields: [objectId], references: [id], onDelete: Cascade)
  priorityDirection PriorityDirection @relation(fields: [priorityDirectionId], references: [id], onDelete: Cascade)

  @@id([objectId, priorityDirectionId])
}

model Organization {
  id       Int     @id @default(autoincrement())
  objectId Int
  name     String
  website  String?

  object Object @relation(fields: [objectId], references: [id], onDelete: Cascade)
}

model ImportHistory {
  id           Int       @id @default(autoincrement())
  userId       Int
  filename     String
  status       String    @default("PROCESSING")
  totalRows    Int
  successRows  Int
  errorRows    Int
  errors       Json?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  user User @relation(fields: [userId], references: [id])
}
